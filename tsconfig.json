{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    // Project setup and output
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "moduleDetection": "force",
    "rootDir": ".",
    "outDir": "./dist",
    "baseUrl": ".",
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "declarationDir": "./typings",

    // Strict type checking
    "strict": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "useDefineForClassFields": true,
    "forceConsistentCasingInFileNames": true,

    // Module / Import behavior (modern ESM-friendly)
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,

    // Output control
    "importHelpers": true,                 // Use tslib helpers
    "stripInternal": true,
    "removeComments": true,
    "preserveConstEnums": true,

    // TypeScript 5.8+ features
    "erasableSyntaxOnly": true,            // Enforce pure/erasable TS syntax only
    "libReplacement": false,               // Small perf win

    // Environment
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "typeRoots": ["node_modules/@types/", "./types/"],

    // Performance & DX
    "skipLibCheck": true,
    "incremental": true,
    "tsBuildInfoFile": "node_modules/.tmp/.tsbuildinfo"
  },
  "include": ["src/**/*", "test/**/*"],
  "exclude": ["node_modules", "dist", "typings"]
}
